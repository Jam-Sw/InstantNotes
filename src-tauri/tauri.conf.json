{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InstantNotes",
  "version": "0.5.0",
  "identifier": "com.instantnotes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "library",
        "title": "InstantNotes",
        "url": "/",
        "width": 980,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "visible": true
      },
      {
        "label": "capture",
        "title": "InstantNotes Capture",
        "url": "/capture",
        "width": 560,
        "height": 160,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "center": true,
        "visible": false,
        "closable": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Jam-Sw/InstantNotes/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1RkY2RjY3ODhFQjU4RDUKUldUVldPdUlaMi8vRlVWZmNwdXpvMmMvbVp2c3ozMFIvREVNcEF0STlJakNHcFh5Um9SUVZLdG0K"
    }
  }
}
